# Ollama
OLLAMA_MODEL=granite4.1:3b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_NUM_PREDICT=512
# OLLAMA_REASONING=true
# OLLAMA_FORMAT=json
# OLLAMA_VALIDATE_MODEL_ON_INIT=false

# Agent
AGENT_SYSTEM_PROMPT=You are a helpful assistant. Please respond to the user's request.

# LangGraph
LANGGRAPH_RECURSION_LIMIT=25
LANGGRAPH_STREAM_MODE=updates

# App
LOG_LEVEL=INFO
