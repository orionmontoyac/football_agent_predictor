# Ollama
OLLAMA_MODEL=granite4.1:3b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEMPERATURE=0.3
# OLLAMA_NUM_PREDICT=1024

# Agent — football prediction analyst (override to customize)
# AGENT_SYSTEM_PROMPT=You are a football match analyst...

# Polymarket (live odds enrichment)
POLYMARKET_ENABLED=true
# POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
# POLYMARKET_WORLD_CUP_SERIES_ID=11433
# POLYMARKET_CACHE_TTL_SECONDS=300
# POLYMARKET_TIMEOUT_SECONDS=15
# POLYMARKET_MARKET_WEIGHT=0.6

# LangGraph
LANGGRAPH_RECURSION_LIMIT=25
LANGGRAPH_STREAM_MODE=updates

# App
LOG_LEVEL=INFO
